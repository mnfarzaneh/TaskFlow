<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TaskFlow.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#EFF6E2</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">#5A7D24</item>
        <item name="postSplashScreenTheme">@style/Theme.TaskFlow</item>
    </style>

    <style name="Theme.TaskFlow" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>